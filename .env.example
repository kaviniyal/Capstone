# Arsh Nivlabs Gateway (OpenAI-compatible)
OPENAI_API_KEY=learner001
OPENAI_BASE_URL=https://keygateway.arshnivlabs.com/v1

# LangSmith Monitoring (get from https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=insurance-claims-intelligence

# Pinecone (create a free index at https://app.pinecone.io)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=insurance-claims
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Embeddings model
EMBEDDING_MODEL=text-embedding-3-small

# LLM model
LLM_MODEL=gpt-4o-mini

# Fraud score thresholds
HITL_LOW_THRESHOLD=0.4
HITL_HIGH_THRESHOLD=0.6

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
