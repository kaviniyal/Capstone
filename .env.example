# OpenAI
OPENAI_API_KEY=sk-...

# LangSmith Monitoring (get from https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=insurance-claims-intelligence

# ChromaDB (local by default, or set remote)
CHROMA_PERSIST_DIR=./data/chroma_db

# Embeddings model
EMBEDDING_MODEL=text-embedding-3-small

# LLM model
LLM_MODEL=gpt-4o-mini

# Fraud score thresholds
HITL_LOW_THRESHOLD=0.4
HITL_HIGH_THRESHOLD=0.6

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
